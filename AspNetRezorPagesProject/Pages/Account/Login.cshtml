@page
@model AspNetRezorPagesProject.Pages.Account.LoginModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

    <div class="auth-card">

    <h2 class="auth-title">Вход</h2>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["StatusMessage"]
        </div>
    }
    <form method="post" novalidate>

        <div class="form-group">
            <label asp-for="LoginDto.Email" class="auth-label">Электронная почта</label>
            <input asp-for="LoginDto.Email" class="form-control" />
            <span asp-validation-for="LoginDto.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LoginDto.Password" class="auth-label">Пароль</label>
            <input asp-for="LoginDto.Password" type="password" class="form-control" />
            <span asp-validation-for="LoginDto.Password" class="text-danger"></span>
        </div>

        <div class="auth-link">
            <a asp-page="/Account/ForgotPassword">Забыли пароль?</a>
        </div>
        <button type="submit" class="btn-primary">Войти</button>

        <div class="auth-link">
            <span>Еще нет аккаунта?</span>
            <a asp-page="/Account/Register">Зарегистрироваться</a>
        </div>


    </form>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
